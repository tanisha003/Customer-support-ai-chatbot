# Copy this file to backend/.env and fill in real values.

# ─── LLM Provider ─────────────────────────────────────────────
# Options: ollama (local) | groq (cloud, free tier)
LLM_PROVIDER=groq

# ─── Ollama (local development) ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Groq (cloud / production) ────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ─── Embeddings (Jina AI hosted API — no local model needed) ──
# Get a free API key at https://jina.ai/?sui=apikey
JINA_API_KEY= jina_e3b2818cef7a4b3a9cf0cda9b707e002O9jY3v6ajbcrnXFMq7FqDKs24LvD
 

# ─── Vector store ─────────────────────────────────────────────
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=support_kb

# ─── Retrieval tuning ─────────────────────────────────────────
TOP_K=4
SIMILARITY_THRESHOLD=0.3

# ─── Server ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
