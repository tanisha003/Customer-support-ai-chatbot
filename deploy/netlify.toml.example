# Netlify config — auto-detected when this file lives in the linked base directory.
# When importing this repo on Netlify, set "Base directory" to `frontend`.

[build]
  command = "npm run build"
  publish = "dist"

[build.environment]
  NODE_VERSION = "20"

# SPA routing — send everything through index.html
[[redirects]]
  from   = "/*"
  to     = "/index.html"
  status = 200

# Sensible default security headers
[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options        = "DENY"
    X-Content-Type-Options = "nosniff"
    Referrer-Policy        = "strict-origin-when-cross-origin"
